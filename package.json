{
  "name": "@markdownkit/md-docx",
  "version": "2.3.1",
  "description": "Convert Markdown to DOCX and DOCX to Markdown with rich formatting and a standalone CLI",
  "keywords": [
    "converter",
    "docx",
    "docx-to-markdown",
    "markdown",
    "markdown-to-docx",
    "markdownkit",
    "typescript",
    "word"
  ],
  "homepage": "https://github.com/markdown-kit/md-docx#readme",
  "bugs": {
    "url": "https://github.com/markdown-kit/md-docx/issues"
  },
  "license": "MIT",
  "author": "Dominikos Pritis",
  "repository": {
    "type": "git",
    "url": "https://github.com/markdown-kit/md-docx.git"
  },
  "bin": {
    "docx-to-md": "./dist/cli.js",
    "dtm": "./dist/cli.js",
    "md-docx": "./dist/cli.js",
    "md-to-docx": "./dist/cli.js",
    "mtd": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --maxWorkers=1",
    "test:alignment": "vitest run tests/heading-alignment.test.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:ci": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "lint:fix-unsafe": "oxlint --import-plugin --node-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions --fix-dangerously .",
    "check:fix-suggestions": "oxlint --import-plugin --node-plugin --type-aware --type-check --vitest-plugin --fix --fix-suggestions . && oxfmt --write .",
    "check": "pnpm run format:check && pnpm run lint:ci && pnpm run typecheck",
    "check:full": "pnpm run check && pnpm run test",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "mammoth": "^1.12.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "jszip": "^3.10.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.x"
  }
}
